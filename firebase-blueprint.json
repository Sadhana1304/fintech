{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User specific settings and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string", "description": "User's preferred currency symbol (e.g., ₹, $)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "type", "category", "date"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget for a specific category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "category", "amount", "month", "year"]
    },
    "Category": {
      "title": "Category",
      "description": "Custom transaction categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "color", "type"]
    },
    "SavingsGoal": {
      "title": "Savings Goal",
      "description": "Financial goals for savings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "targetAmount", "currentAmount"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "All income and expense transactions"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Monthly category budgets"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "User-defined categories"
    },
    "/savingsGoals/{goalId}": {
      "schema": "SavingsGoal",
      "description": "User savings goals"
    }
  }
}
